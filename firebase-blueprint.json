{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item in the supply chain inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string", "description": "e.g., kg, liters, units" },
        "minStockLevel": { "type": "number" },
        "currentStock": { "type": "number" },
        "price": { "type": "number" },
        "supplierId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "unit", "minStockLevel", "currentStock", "price"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A vendor providing products.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "leadTime": { "type": "number", "description": "Average delivery time in days" }
      },
      "required": ["name", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order to a supplier.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "supplierId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "items", "status", "totalAmount"]
    },
    "InventoryLog": {
      "title": "Inventory Log",
      "description": "Audit trail for stock changes.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "change": { "type": "number" },
        "type": { "type": "string", "enum": ["purchase", "sale", "adjustment", "loss"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "required": ["productId", "change", "type", "timestamp"]
    },
    "Forecast": {
      "title": "Demand Forecast",
      "description": "AI-generated demand predictions.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "predictedDemand": { "type": "number" },
        "period": { "type": "string", "description": "Month/Year string" },
        "confidence": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "predictedDemand", "period"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of inventory products."
    },
    "suppliers": {
      "schema": "Supplier",
      "description": "Collection of verified suppliers."
    },
    "orders": {
      "schema": "Order",
      "description": "Supply chain purchase orders."
    },
    "inventoryLogs": {
      "schema": "InventoryLog",
      "description": "History of stock adjustments."
    },
    "forecasts": {
      "schema": "Forecast",
      "description": "AI demand forecasting data."
    }
  }
}
